# Predict Account trading template.
# Start on testnet for safer verification; switch to mainnet only after adding a valid API key.

PREDICT_STORAGE_DIR=~/.openclaw/predict
PREDICT_ENV=testnet
PREDICT_API_BASE_URL=https://api-testnet.predict.fun
PREDICT_WALLET_MODE=predict-account
PREDICT_API_KEY=
PREDICT_ACCOUNT_ADDRESS=0xYOUR_PREDICT_ACCOUNT
PREDICT_PRIVY_PRIVATE_KEY=0xYOUR_PRIVY_EXPORTED_KEY

# Mainnet requires:
# PREDICT_ENV=mainnet
# PREDICT_API_KEY=YOUR_PREDICT_API_KEY
