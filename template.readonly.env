# Live market reads with the smallest realistic configuration.
# Mainnet requires a valid API key even for market reads.
# If you want secret-free local verification instead, copy `template.env`.

PREDICT_STORAGE_DIR=~/.openclaw/predict
PREDICT_ENV=mainnet
PREDICT_API_BASE_URL=
PREDICT_WALLET_MODE=read-only
PREDICT_API_KEY=

# Optional unauthenticated testnet alternative:
# PREDICT_ENV=testnet
# PREDICT_API_BASE_URL=https://api-testnet.predict.fun
# PREDICT_API_KEY=
