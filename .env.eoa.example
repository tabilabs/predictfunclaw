# EOA trading template.
# Start on testnet for safer verification; switch to mainnet only after adding a valid API key.

PREDICT_STORAGE_DIR=~/.openclaw/predict
PREDICT_ENV=testnet
PREDICT_API_BASE_URL=https://api-testnet.predict.fun
PREDICT_WALLET_MODE=eoa
PREDICT_API_KEY=
PREDICT_PRIVATE_KEY=0xYOUR_EOA_PRIVATE_KEY

# Mainnet requires:
# PREDICT_ENV=mainnet
# PREDICT_API_KEY=YOUR_PREDICT_API_KEY
