# Copy this file to ~/.openclaw/skills/predictclaw/.env after installing PredictClaw.
# PredictClaw reads plain environment variables; this local .env file is the recommended
# first-time configuration surface for packaged installs.
# Exported shell variables override values in this file.

# Core runtime
# This default file is intentionally bootstrap-safe: it uses local fixture data,
# explicit read-only mode, and no network or secrets. For live reads or trading,
# start from one of these focused templates instead:
# - template.readonly.env
# - template.eoa.env
# - template.predict-account.env
# - template.mandated-vault.env
PREDICT_STORAGE_DIR=~/.openclaw/predict
PREDICT_ENV=test-fixture
# Leave empty to use the env-specific default:
# - testnet -> https://api-testnet.predict.fun
# - test-fixture -> ignored (fixture mode does not hit the network)
# - mainnet -> https://api.predict.fun
PREDICT_API_BASE_URL=

# Wallet mode override (set one of: read-only, eoa, predict-account, mandated-vault)
PREDICT_WALLET_MODE=read-only

# Mainnet-only API auth. Leave empty in fixture mode.
PREDICT_API_KEY=

# EOA mode (set this for direct private-key usage)
PREDICT_PRIVATE_KEY=

# Predict Account mode (set both values to use smart-wallet flows)
PREDICT_ACCOUNT_ADDRESS=
PREDICT_PRIVY_PRIVATE_KEY=

# Mandated vault overlay / control-plane inputs (advanced explicit opt-in only)
# - Pure control-plane mode still uses `PREDICT_WALLET_MODE=mandated-vault`.
# - The preferred trading route now uses `PREDICT_WALLET_MODE=predict-account` together
#   with `ERC_MANDATED_*` so Vault funds the Predict Account while the Predict Account
#   remains the official deposit/trading address.
# - Use ERC_MANDATED_VAULT_ADDRESS when you already know the deployed vault address.
# - Otherwise provide the full derivation tuple below so PredictClaw can ask the MCP to
#   predict the vault address and prepare route/funding guidance.
# - The MCP orchestrates transport/preparation; the vault contract policy authorizes what
#   the vault can actually execute.
# - Preflight signer MVP: set ERC_MANDATED_AUTHORITY_PRIVATE_KEY for the single-key path.
#   ERC_MANDATED_EXECUTOR_PRIVATE_KEY is optional and falls back to the authority key when unset.
ERC_MANDATED_VAULT_ADDRESS=
ERC_MANDATED_FACTORY_ADDRESS=
ERC_MANDATED_VAULT_ASSET_ADDRESS=
ERC_MANDATED_VAULT_NAME=
ERC_MANDATED_VAULT_SYMBOL=
ERC_MANDATED_VAULT_AUTHORITY=
ERC_MANDATED_VAULT_SALT=
ERC_MANDATED_AUTHORITY_PRIVATE_KEY=
ERC_MANDATED_EXECUTOR_PRIVATE_KEY=
# Leave these empty unless you are explicitly enabling overlay / mandated-vault.
# When unset, PredictClaw falls back to its built-in defaults.
ERC_MANDATED_MCP_COMMAND=
ERC_MANDATED_CONTRACT_VERSION=
ERC_MANDATED_CHAIN_ID=
# Optional 32-byte hex adapter allowlist root for Vault execution mandates.
# Defaults in code to 0x1111...1111 for the current single-key MVP / PoC path.
ERC_MANDATED_ALLOWED_ADAPTERS_ROOT=
# Optional funding-policy limits for Vault -> Predict Account transfers.
# Amounts are raw token units; on BSC mainnet USDT (18 decimals): 5U=5000000000000000000.
ERC_MANDATED_FUNDING_MAX_AMOUNT_PER_TX=
ERC_MANDATED_FUNDING_MAX_AMOUNT_PER_WINDOW=
ERC_MANDATED_FUNDING_WINDOW_SECONDS=

# Hedge / LLM configuration
OPENROUTER_API_KEY=
PREDICT_MODEL=openrouter/openai/gpt-4.1-mini

# Fixture + smoke-test gating
PREDICT_SMOKE_ENV=testnet
PREDICT_SMOKE_API_BASE_URL=https://api-testnet.predict.fun
PREDICT_SMOKE_PRIVATE_KEY=
PREDICT_SMOKE_ACCOUNT_ADDRESS=
PREDICT_SMOKE_PRIVY_PRIVATE_KEY=
PREDICT_SMOKE_API_KEY=
